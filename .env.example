# ── Required ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Optional: Auth ──
# Comma-separated Telegram user IDs. Leave empty to allow all users.
# Use the /whoami command on the bot to find your user ID.
ALLOWED_USER_IDS=

# ── Optional: OpenAI ──
# Model to use for parsing (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Optional: Company/Sender Info ──
# These appear as the "From" section on every invoice.
COMPANY_NAME=
COMPANY_ADDRESS=
COMPANY_EMAIL=
COMPANY_PHONE=

# ── Optional: Bank/Payment Details ──
# Shown in the "Payment Details" section of the invoice.
COMPANY_BANK_NAME=
COMPANY_BANK_ACCOUNT_NUMBER=
COMPANY_BANK_SORT_CODE=

# ── Optional: Paths ──
# Path to a company logo image (PNG/JPG). Mount into the container.
COMPANY_LOGO_PATH=
# Path to a custom style YAML file. Mount into the container.
INVOICE_STYLE_PATH=
